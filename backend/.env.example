# Database Configuration
DATABASE_URL=postgresql://kandakorlik_user:secure_password_change_me@localhost:5432/kandakorlik_db

# JWT Security
SECRET_KEY=your-super-secret-key-change-this-to-a-random-string-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Translation Service (Choose: deepl or google)
TRANSLATION_SERVICE=deepl
DEEPL_API_KEY=your-deepl-api-key-here
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key-here

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:3000"]

# Application
APP_NAME=Kandakorlik Quiz API
VERSION=1.0.0
